<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rdr.roast.ui.RoastPropertiesController"
      styleClass="drawer-form"
      spacing="10" alignment="TOP_LEFT" minWidth="400" prefWidth="400" fillWidth="true">
    <Label text="Свойства обжарки" styleClass="drawer-sheet-title"/>
    <Label text="Подготовьте название, эталон и веса партии." styleClass="drawer-sheet-subtitle"/>

    <GridPane hgap="12" vgap="8" styleClass="drawer-section-card, drawer-hero-card">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>
        <Label text="Профиль партии" styleClass="secondary-section-title"/>
        <Label text="Title / Название" styleClass="secondary-field-label" GridPane.columnSpan="2" GridPane.rowIndex="1"/>
        <TextField fx:id="txtTitle" promptText="Название профиля" styleClass="secondary-input" GridPane.columnSpan="2" GridPane.rowIndex="2"/>
        <Label text="Stock / Склад" styleClass="secondary-field-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Label text="Blend / Бленд" styleClass="secondary-field-label" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <ComboBox fx:id="cmbStock" promptText="— Не выбрано —" styleClass="secondary-combo" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <ComboBox fx:id="cmbBlend" promptText="— Не выбрано —" styleClass="secondary-combo" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Label text="Reference / Эталон" styleClass="secondary-field-label" GridPane.columnSpan="2" GridPane.rowIndex="5"/>
        <ComboBox fx:id="cmbReference" promptText="— Без эталона —" styleClass="secondary-combo" GridPane.columnSpan="2" GridPane.rowIndex="6"/>
    </GridPane>

    <GridPane hgap="12" vgap="8" styleClass="drawer-section-card, secondary-grid">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>
        <Label text="Вес зелёного" styleClass="secondary-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label text="Вес после обжарки" styleClass="secondary-field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="txtWeightIn" promptText="0.0" styleClass="secondary-input" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtWeightOut" promptText="0.0" styleClass="secondary-input" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="кг зелёного кофе" styleClass="secondary-hint-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label text="кг готового кофе" styleClass="secondary-hint-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <VBox spacing="8" styleClass="drawer-section-card">
        <Label text="Beans / Заметки" styleClass="secondary-field-label"/>
        <TextArea fx:id="txtBeans" promptText="Описание зелёного кофе, заметки..." prefRowCount="2" wrapText="true" styleClass="secondary-input"/>
    </VBox>

    <HBox spacing="8" alignment="CENTER_LEFT" styleClass="drawer-toolbar">
        <Button fx:id="btnLoadFile" text="Загрузить .alog" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnCancel" text="Отмена" cancelButton="true" styleClass="btn-secondary"/>
        <Button fx:id="btnOk" text="Сохранить" defaultButton="true" styleClass="btn-primary"/>
    </HBox>
</VBox>
