<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rdr.roast.ui.MainController"
            styleClass="root-pane">

    <!-- Custom title bar: draggable, min/max/close -->
    <top>
        <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT" spacing="6">
            <HBox alignment="CENTER_LEFT" spacing="6" styleClass="title-bar-brand">
                <StackPane styleClass="title-bar-brand-orb">
                    <ImageView fitWidth="16" fitHeight="16" preserveRatio="true" pickOnBounds="true">
                        <image>
                            <Image url="@../app-icon.png"/>
                        </image>
                    </ImageView>
                </StackPane>
                <Label text="RDR" styleClass="title-bar-label"/>
            </HBox>
            <HBox fx:id="roasterConnectionBox" alignment="CENTER_LEFT" spacing="6" styleClass="roaster-connection-indicator">
                <Region fx:id="roasterConnectionDot" styleClass="roaster-connection-dot"/>
                <Label fx:id="lblRoasterName" text="—" styleClass="roaster-connection-label"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="6" styleClass="title-bar-actions">
                <Button fx:id="btnShowSliders" styleClass="title-bar-btn, title-bar-sliders-btn" visible="false" managed="false"
                        minWidth="30" maxWidth="30" minHeight="30" maxHeight="30" prefWidth="30" prefHeight="30"/>
                <ComboBox fx:id="sliderLayoutCombo" visible="false" managed="false" maxWidth="140" minHeight="30" prefHeight="30"
                          styleClass="title-bar-combo"/>
                <Button fx:id="btnSettings" styleClass="title-bar-btn, title-bar-utility-btn"
                        minWidth="32" maxWidth="32" minHeight="32" maxHeight="32" prefWidth="32" prefHeight="32">
                    <tooltip><Tooltip text="Settings"/></tooltip>
                </Button>
            </HBox>
            <Button fx:id="btnShortcuts" visible="false" managed="false"/>
            <HBox alignment="CENTER_RIGHT" spacing="4" styleClass="title-bar-window-controls">
                <Button fx:id="btnMinimize" styleClass="title-bar-btn, title-bar-window-btn"
                        minWidth="32" maxWidth="32" minHeight="32" maxHeight="32" prefWidth="32" prefHeight="32"/>
                <Button fx:id="btnMaximize" styleClass="title-bar-btn, title-bar-window-btn"
                        minWidth="32" maxWidth="32" minHeight="32" maxHeight="32" prefWidth="32" prefHeight="32"/>
                <Button fx:id="btnClose" styleClass="title-bar-btn, title-bar-window-btn, title-bar-close-btn"
                        minWidth="32" maxWidth="32" minHeight="32" maxHeight="32" prefWidth="32" prefHeight="32"/>
            </HBox>
            <Button fx:id="btnSync" visible="false" managed="false"/>
        </HBox>
    </top>

    <!-- Left: sidebar column (buttons) -->
    <left>
        <HBox fx:id="leftSidebarRegion" styleClass="left-sidebar-region" spacing="0" BorderPane.alignment="CENTER_LEFT">
            <VBox fx:id="sidebarColumn" styleClass="sidebar-column" alignment="TOP_CENTER">
                <padding><Insets top="14" bottom="14"/></padding>
                <VBox styleClass="sidebar-nav-group" alignment="TOP_CENTER" spacing="8">
                    <ToggleButton fx:id="btnSidebarPlan" styleClass="sidebar-btn, sidebar-nav-btn"/>
                    <ToggleButton fx:id="btnSidebarProduction" styleClass="sidebar-btn, sidebar-nav-btn"/>
                    <ToggleButton fx:id="btnSidebarSupport" styleClass="sidebar-btn, sidebar-nav-btn"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <VBox spacing="8" alignment="CENTER" styleClass="sidebar-action-group">
                    <Button fx:id="btnAbort" styleClass="sidebar-btn, sidebar-action-btn"/>
                    <Button fx:id="btnStart" styleClass="sidebar-btn, sidebar-action-btn"/>
                    <Button fx:id="btnStop" styleClass="sidebar-btn, sidebar-action-btn"/>
                </VBox>
                <ToggleButton fx:id="btnSidebarAccount" styleClass="sidebar-btn, sidebar-account-btn"/>
            </VBox>
        </HBox>
    </left>

    <!-- Center: HBox [ SplitPane (chart | right panel) | slider drawer column ] -->
    <center>
        <HBox fx:id="centerHBox" spacing="0">
            <SplitPane fx:id="centerSplit" styleClass="center-split" dividerPositions="0.8" HBox.hgrow="ALWAYS">
                <!-- Left: chart area (main chart + control chart below) -->
                <BorderPane fx:id="centerPane" style="-fx-background-color: transparent;">
                    <center>
                        <VBox alignment="TOP_CENTER" spacing="0">
                            <Pane fx:id="chartContainer" VBox.vgrow="ALWAYS" style="-fx-background-color: -rdr-chart-bg;">
                                <padding><Insets top="2" right="2" bottom="2" left="2"/></padding>
                                <StackPane fx:id="sidebarPanelContainer" styleClass="sidebar-panel-container"
                                           minWidth="0" prefWidth="0"/>
                            </Pane>
                            <Pane fx:id="controlChartContainer" minHeight="0" prefHeight="0" maxHeight="0"
                                  visible="false" managed="false"
                                  style="-fx-background-color: -rdr-chart-bg; -fx-border-color: -rdr-border; -fx-border-width: 1 0 0 0;"/>

                            <FlowPane fx:id="presetButtonsPanel" hgap="8" vgap="6"
                                      alignment="CENTER" visible="false" managed="false"
                                      styleClass="preset-buttons-panel">
                                <padding><Insets top="6" right="12" bottom="6" left="12"/></padding>
                            </FlowPane>
                        </VBox>
                    </center>
                </BorderPane>

                <!-- Right: fixed-width panel (Reference, Comments, Values, Pre-heat, Sliders button only); scrollable when height is limited -->
                <HBox fx:id="rightPanel" styleClass="right-panel"
                      minWidth="302" prefWidth="302" maxWidth="302" spacing="0">
                    <ScrollPane fx:id="rightPanelScroll" fitToWidth="true" HBox.hgrow="ALWAYS"
                                styleClass="right-panel-scroll"
                                style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
                        <VBox fx:id="rightPanelContent" minWidth="200" spacing="12" styleClass="right-panel-content">
                <!-- Reference block -->
                <VBox fx:id="referencePanel" styleClass="reference-panel, premium-card, premium-card-reference" spacing="2"
                      visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label text="Reference roast" styleClass="right-panel-header"/>
                    </HBox>
                    <Label fx:id="lblReferenceLabel" text="No reference roast selected."
                           style="-fx-text-fill: -rdr-text-hint; -fx-font-size: 10px;"/>
                    <VBox fx:id="referenceSummaryBox" spacing="1" visible="false" managed="false">
                        <GridPane hgap="6" vgap="1">
                            <columnConstraints>
                                <ColumnConstraints minWidth="96" prefWidth="96"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="Total time" styleClass="reference-summary-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="lblRefDuration" text="--:--" styleClass="reference-summary-value"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label text="Charge temp" styleClass="reference-summary-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="lblRefChargeTemp" text="-- °C" styleClass="reference-summary-value"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label text="Drop temp" styleClass="reference-summary-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label fx:id="lblRefDropTemp" text="-- °C" styleClass="reference-summary-value"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            <Label text="Development" styleClass="reference-summary-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <Label fx:id="lblRefDevTime" text="--:--" styleClass="reference-summary-value"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            <Label text="Development %" styleClass="reference-summary-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <Label fx:id="lblRefDevTimeRatio" text="--%" styleClass="reference-summary-value"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        </GridPane>
                    </VBox>
                </VBox>

                <VBox fx:id="bbpPanel" styleClass="reference-panel, premium-card, premium-card-bbp" spacing="2"
                      visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label text="Between batch" styleClass="right-panel-header"/>
                    </HBox>
                    <Label fx:id="lblBbpStatus" text="Recording between batch data"
                           style="-fx-text-fill: -rdr-text-primary; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblBbpReference" text="No reference between batch data."
                           style="-fx-text-fill: -rdr-text-hint; -fx-font-size: 10px;"/>
                    <Label fx:id="lblBbpMinBt" text="Lowest BT: —"
                           style="-fx-text-fill: -rdr-text-secondary; -fx-font-size: 10px;"/>
                    <Label fx:id="lblBbpMaxBt" text="Highest BT: —"
                           style="-fx-text-fill: -rdr-text-secondary; -fx-font-size: 10px;"/>
                    <Label fx:id="lblBbpHint" text="Click the chart to add a comment, gas or airflow."
                           style="-fx-text-fill: -rdr-text-hint; -fx-font-size: 10px; -fx-wrap-text: true;"/>
                </VBox>

                <!-- Comments block (limited height) -->
                <VBox fx:id="commentsBlock" styleClass="right-panel-section, comments-section, premium-card, premium-card-comments" spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label fx:id="lblCommentsHeader" text="Events &amp; comments" styleClass="comments-header"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnCommentsCollapse" styleClass="title-bar-btn collapse-btn"
                                style="-fx-min-width: 20; -fx-max-width: 20; -fx-min-height: 20; -fx-max-height: 20;"/>
                        <Button fx:id="btnCommentsSettings" styleClass="title-bar-btn"
                                style="-fx-min-width: 20; -fx-max-width: 20; -fx-min-height: 20; -fx-max-height: 20;"/>
                    </HBox>
                    <ListView fx:id="commentsListView" styleClass="comments-list" VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- Live values block -->
                <VBox fx:id="valuesPanel" spacing="8" alignment="TOP_LEFT"
                      styleClass="premium-card, premium-card-metrics">
                    <Label text="Live metrics" styleClass="right-panel-eyebrow"/>
                    <!-- BT left | ET right -->
                    <HBox spacing="8" alignment="TOP_LEFT" fillHeight="false" styleClass="metric-cards-row">
                        <!-- Bean temp (left) -->
                        <VBox spacing="2" minWidth="0" HBox.hgrow="ALWAYS" styleClass="metric-card, metric-card-bt">
                            <HBox alignment="BASELINE_LEFT" spacing="2">
                                <Label fx:id="lblBTValue" text="--.-" styleClass="readout-value-bt"/>
                                <Label fx:id="lblBTUnit" text=" °C" styleClass="readout-unit-bt"/>
                            </HBox>
                            <Label text="Bean temp" styleClass="readout-label-bt"/>
                            <HBox alignment="BASELINE_LEFT" spacing="2">
                                <Label fx:id="lblRoRBTValue" text="--.-" styleClass="readout-ror-value-bt"/>
                                <Label fx:id="lblRoRBTUnit" text=" °C/min" styleClass="readout-unit-bt"/>
                            </HBox>
                            <Label text="RoR" styleClass="readout-label-bt"/>
                        </VBox>
                        <!-- Exhaust (right) -->
                        <VBox spacing="2" minWidth="0" HBox.hgrow="ALWAYS" styleClass="metric-card, metric-card-et">
                            <HBox alignment="BASELINE_LEFT" spacing="2">
                                <Label fx:id="lblETValue" text="--.-" styleClass="readout-value-et"/>
                                <Label fx:id="lblETUnit" text=" °C" styleClass="readout-unit-et"/>
                            </HBox>
                            <Label text="Exhaust temp" styleClass="readout-label-et"/>
                            <HBox alignment="BASELINE_LEFT" spacing="2">
                                <Label fx:id="lblRoRETValue" text="--.-" styleClass="readout-ror-value-et"/>
                                <Label fx:id="lblRoRETUnit" text=" °C/min" styleClass="readout-unit-et"/>
                            </HBox>
                            <Label text="RoR" styleClass="readout-label-et"/>
                        </VBox>
                    </HBox>
                    <!-- Extra sensor readouts (dynamically populated) -->
                    <FlowPane fx:id="extraSensorReadouts" hgap="8" vgap="6"
                              visible="false" managed="false"
                              styleClass="extra-readouts-pane"/>
                    <!-- Timer (centered, prominent) -->
                    <VBox alignment="CENTER_LEFT" spacing="4" styleClass="timer-hero-card">
                        <Label text="Current stage" styleClass="timer-hero-caption"/>
                        <HBox fx:id="timerHeroPanel" alignment="CENTER" styleClass="readout-timer-panel" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblDuration" text="Preheat" styleClass="readout-timer"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox fx:id="customButtonsPanel" spacing="4" alignment="CENTER"
                      visible="false" managed="false"
                      styleClass="premium-card, right-panel-actions"/>

                <VBox spacing="6" alignment="CENTER" styleClass="premium-card, right-panel-actions">
                    <HBox alignment="CENTER" spacing="8">
                        <Button fx:id="btnRestartBbp" text="Restart recording" visible="false" managed="false"/>
                        <Button fx:id="btnStopBbp" text="Stop recording" visible="false" managed="false"/>
                    </HBox>
                </VBox>
                </VBox>
                    </ScrollPane>
                    <!-- Slider drawer: lives inside rightPanel HBox, pushes content left when open -->
                    <VBox fx:id="sliderDrawerPanel" styleClass="slider-drawer-panel"
                          minWidth="0" prefWidth="0" maxWidth="320"
                          visible="false" managed="false"/>
            </HBox>
        </SplitPane>
        </HBox>
    </center>
</BorderPane>
