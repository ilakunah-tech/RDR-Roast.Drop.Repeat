<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rdr.roast.ui.SettingsController"
      spacing="0" alignment="TOP_CENTER"
      style="-fx-background-color: #ffffff; -fx-padding: 16; -fx-text-fill: #333333;">
    <fx:define>
        <ToggleGroup fx:id="tglUnit"/>
    </fx:define>

    <TabPane fx:id="settingsTabPane" VBox.vgrow="ALWAYS">
        <Tab text="Тема">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="Тема оформления"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <ComboBox fx:id="cmbTheme" prefWidth="280"/>

                    <Label text="Масштаб интерфейса"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <ComboBox fx:id="cmbScale" prefWidth="280"/>

                    <Label text="Размер шрифта"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <ComboBox fx:id="cmbFontSize" prefWidth="280"/>

                    <Label text="Плотность интерфейса"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <ComboBox fx:id="cmbDensity" prefWidth="280"/>

                    <Label text="Скругление углов"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Slider fx:id="sldRadius" min="0" max="20" value="10" blockIncrement="1" majorTickUnit="5" minorTickCount="0" showTickLabels="false" showTickMarks="false" prefWidth="200"/>
                        <Label fx:id="lblRadiusValue" text="10px" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <Button fx:id="btnRadiusReset" text="Сброс"
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                    </HBox>

                    <Label text="Акцентный цвет"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ColorPicker fx:id="colorAccent"/>
                        <Button fx:id="btnAccentDefault" text="По умолчанию"
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="Пресеты:" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <Button fx:id="btnPresetPeach" styleClass="accent-preset" style="-fx-background-color: #E8896A; -fx-min-width: 20; -fx-max-width: 20; -fx-min-height: 20; -fx-max-height: 20; -fx-background-radius: 10;"/>
                        <Button fx:id="btnPresetTeal" styleClass="accent-preset" style="-fx-background-color: #4AABA8; -fx-min-width: 20; -fx-max-width: 20; -fx-min-height: 20; -fx-max-height: 20; -fx-background-radius: 10;"/>
                        <Button fx:id="btnPresetIndigo" styleClass="accent-preset" style="-fx-background-color: #5C6BC0; -fx-min-width: 20; -fx-max-width: 20; -fx-min-height: 20; -fx-max-height: 20; -fx-background-radius: 10;"/>
                        <Button fx:id="btnPresetSage" styleClass="accent-preset" style="-fx-background-color: #7BAE7F; -fx-min-width: 20; -fx-max-width: 20; -fx-min-height: 20; -fx-max-height: 20; -fx-background-radius: 10;"/>
                        <Button fx:id="btnPresetRose" styleClass="accent-preset" style="-fx-background-color: #C2666E; -fx-min-width: 20; -fx-max-width: 20; -fx-min-height: 20; -fx-max-height: 20; -fx-background-radius: 10;"/>
                    </HBox>

                    <Label text="Цвет фона панелей (боковая панель, drawer)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ColorPicker fx:id="colorPanelBg"/>
                        <Button fx:id="btnPanelBgDefault" text="По умолчанию"
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                    </HBox>

                    <Label text="Применить все настройки темы к главному окну"
                           style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 8 0 0 0;">
                        <Button fx:id="btnApplyTheme" text="Применить"
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                        <Button fx:id="btnRestoreAppearance" text="Восстановить по умолчанию"
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </Tab>
        <Tab text="Подключение">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="Источник данных"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <ComboBox fx:id="cmbSource" prefWidth="280"
                              style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>

                    <Label fx:id="lblEtBtSource" text="ET/BT source: —"
                           style="-fx-font-size: 12px; -fx-text-fill: #666666; -fx-wrap-text: true;"/>

                    <Label text="Профиль подключения"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cmbPreset" prefWidth="180" promptText="— Текущий —"
                                  style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Button fx:id="btnLoadPreset" text="Загрузить"
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                        <Button fx:id="btnSavePreset" text="Сохранить как..."
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                    </HBox>

                    <Label text="Параметры подключения"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <VBox fx:id="portFieldsContainer" spacing="12" style="-fx-background-color: transparent;">
                        <GridPane hgap="16" vgap="8" style="-fx-background-color: transparent;">
                            <columnConstraints>
                                <ColumnConstraints minWidth="100" prefWidth="140"/>
                                <ColumnConstraints minWidth="200" prefWidth="280"/>
                            </columnConstraints>
                            <Label text="Транспорт" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <ComboBox fx:id="cmbTransport" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                      style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>

                            <Label fx:id="lblHost" text="Host (TCP)" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtHost" promptText="10.0.0.9" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblTcpPort" text="Port (TCP)" GridPane.columnIndex="0" GridPane.rowIndex="2"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtTcpPort" promptText="502" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblComPort" text="COM Port" GridPane.columnIndex="0" GridPane.rowIndex="3"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                <ComboBox fx:id="cmbPort" prefWidth="200" editable="true" promptText="COM4"
                                          style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                                <Button fx:id="btnRefreshPorts" text="Обновить порты"
                                        style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                            </HBox>

                            <Label fx:id="lblBaudRate" text="Baud Rate" GridPane.columnIndex="0" GridPane.rowIndex="4"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtBaudRate" promptText="9600" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblSlaveId" text="Slave ID" GridPane.columnIndex="0" GridPane.rowIndex="5"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtSlaveId" promptText="1" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="5"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblBtRegister" text="BT Register" GridPane.columnIndex="0" GridPane.rowIndex="6"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtBtRegister" promptText="6" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="6"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblEtRegister" text="ET Register" GridPane.columnIndex="0" GridPane.rowIndex="7"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtEtRegister" promptText="7" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="7"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblDivider" text="Divider (1/x)" GridPane.columnIndex="0" GridPane.rowIndex="8"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtDivider" promptText="10" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="8"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblPhidgetEt" text="Phidget ET channel" GridPane.columnIndex="0" GridPane.rowIndex="9"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtPhidgetEtChannel" promptText="1" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="9"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblPhidgetBt" text="Phidget BT channel" GridPane.columnIndex="0" GridPane.rowIndex="10"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtPhidgetBtChannel" promptText="2" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="10"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        </GridPane>
                        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 8 0 0 0;">
                            <Button fx:id="btnPortsConfig" text="Device Assignment…"
                                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                            <Button fx:id="btnEventButtons" text="Event Buttons…"
                                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                            <Button fx:id="btnTestConnection" text="Проверить подключение"
                                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                            <CheckBox fx:id="chkVerifyBeforeSave" text="Проверить перед сохранением"
                                      style="-fx-text-fill: #555555;"/>
                        </HBox>
                    </VBox>

                    <Label text="Между партиями (BBP)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <CheckBox fx:id="chkBetweenBatchProtocol" text="Display &quot;Between Batch&quot; curves and timer during pre- and post-roast"
                              style="-fx-text-fill: #555555;"/>

                    <Label text="Автоопределение ростера"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <CheckBox fx:id="chkAutoDetectRoaster" text="Определять ростер автоматически при подключении"
                              style="-fx-text-fill: #555555;"/>
                    <CheckBox fx:id="chkRememberLastRoaster" text="Запоминать последний определённый ростер"
                              style="-fx-text-fill: #555555;"/>
                    <Label text="IP для сканирования (через запятую, пусто = по умолчанию)"
                           style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    <TextField fx:id="txtDiscoveryHosts" promptText="10.0.0.9, 192.168.1.100" prefWidth="280"
                               style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                    <Label text="Интервал опроса (сек)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <TextField fx:id="txtSamplingIntervalSec" promptText="0.1–3" prefWidth="80"
                               style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                    <Label text="Event commands (Modbus)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <Label text="write(slaveId,reg,val); wcoil(slaveId,coil,0|1); sleep(sec). Run on C=Charge, D=Drop, DE/FC from chart."
                           style="-fx-text-fill: #888888; -fx-font-size: 11px; -fx-wrap-text: true;"/>
                    <GridPane hgap="12" vgap="6" style="-fx-background-color: transparent;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="80" prefWidth="90"/>
                            <ColumnConstraints minWidth="200" prefWidth="320" hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="CHARGE" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtEventCharge" promptText="write(1,1008,2);sleep(15)" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="DROP" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtEventDrop" promptText="write(1,1008,5)" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="DRY_END (DE)" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtEventDryEnd" promptText="wcoil(1,2005,1)" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="FC_START" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtEventFcStart" promptText="write(1,1008,3)" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="COOL_END" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtEventCoolEnd" promptText="write(1,1008,0)" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </GridPane>

                    <Label text="Единицы температуры"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="16">
                        <RadioButton fx:id="rbCelsius" text="°C" toggleGroup="$tglUnit" selected="true"
                                     style="-fx-text-fill: #333333;"/>
                        <RadioButton fx:id="rbFahrenheit" text="°F" toggleGroup="$tglUnit"
                                     style="-fx-text-fill: #333333;"/>
                    </HBox>

                    <Label text="Папка сохранения (.alog)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8">
                        <TextField fx:id="txtSavePath" prefWidth="220" HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Button fx:id="btnBrowse" text="Обзор..."
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 8 16; -fx-background-radius: 4;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </Tab>

        <Tab text="График">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="График"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>

                    <Label text="Axes (оси графика)"
                           style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button fx:id="btnAxesConfig" text="Axes..."
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                        <Label text="Time / Temperature / Legend / Grid / Delta"
                               style="-fx-text-fill: #777777; -fx-font-size: 11px;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Длительность (мин)" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartTimeRange" prefWidth="50"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>
                    </HBox>

                    <CheckBox fx:id="chkChartShowGrid" text="Показать сетку"
                              style="-fx-text-fill: #333333;"/>
                    <CheckBox fx:id="chkChartShowBt" text="Показывать BT"
                              style="-fx-text-fill: #333333;"/>
                    <CheckBox fx:id="chkChartShowEt" text="Показывать ET"
                              style="-fx-text-fill: #333333;"/>
                    <CheckBox fx:id="chkChartShowRorBt" text="Показывать RoR BT"
                              style="-fx-text-fill: #333333;"/>
                    <CheckBox fx:id="chkChartShowRorEt" text="Показывать RoR ET"
                              style="-fx-text-fill: #333333;"/>
                    <CheckBox fx:id="chkChartShowReferenceCurves" text="Показывать reference curves"
                              style="-fx-text-fill: #333333;"/>
                    <CheckBox fx:id="chkChartShowReferenceEvents" text="Показывать reference events"
                              style="-fx-text-fill: #333333;"/>
                    <CheckBox fx:id="chkChartShowPhaseStrips" text="Показывать phase strips"
                              style="-fx-text-fill: #333333;"/>

                    <Label text="Толщина линий"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="BT" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartBtLineWidth" prefWidth="40" promptText="2"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="ET" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartEtLineWidth" prefWidth="40" promptText="2"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="RoR BT" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartRorLineWidth" prefWidth="40" promptText="1.5"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="RoR ET" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartRefLineWidth" prefWidth="40" promptText="1.5"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </HBox>

                    <Label text="Фон / Сетка"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="txtChartBackground" promptText="#ffffff" prefWidth="80"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <TextField fx:id="txtChartGridColor" promptText="#d3d3d3" prefWidth="80"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </Tab>

        <Tab text="Цвета">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="Живой BT / Живой ET"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>

                    <GridPane hgap="12" vgap="8" style="-fx-background-color: transparent;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="60" prefWidth="70"/>
                            <ColumnConstraints minWidth="120" prefWidth="140"/>
                            <ColumnConstraints minWidth="70" prefWidth="90"/>
                        </columnConstraints>
                        <Label text="BT" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveBt" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtColorLiveBt" promptText="#d4483b" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="0"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="ET" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveEt" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtColorLiveEt" promptText="#3498db" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="1"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="RoR BT" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveRorBt" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtColorLiveRorBt" promptText="#2c3e50" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="2"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="RoR ET" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveRorEt" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtColorLiveRorEt" promptText="#95a5a6" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="3"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </GridPane>

                    <Label text="Цвета reference"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>

                    <GridPane hgap="12" vgap="8" style="-fx-background-color: transparent;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="60" prefWidth="70"/>
                            <ColumnConstraints minWidth="120" prefWidth="140"/>
                            <ColumnConstraints minWidth="70" prefWidth="90"/>
                        </columnConstraints>
                        <Label text="BT" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorRefBt" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtColorRefBt" promptText="#d4483b" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="0"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="ET" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorRefEt" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtColorRefEt" promptText="#3498db" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="1"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </GridPane>

                    <Label text="Прозрачность ref"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Slider fx:id="sldRefAlpha" min="0" max="255" value="80" prefWidth="180" showTickLabels="false" showTickMarks="false"/>
                        <TextField fx:id="txtColorRefAlpha" promptText="80" prefWidth="50"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </HBox>

                    <Button fx:id="btnResetColors" text="Сбросить..."
                            style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                </VBox>
            </ScrollPane>
        </Tab>

        <Tab text="Квантайзеры событий">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="Квантайзеры для слайдеров (Air, Drum, Damper, Burner): Source (ET/BT), SV, Min, Max, Step, Action. Применяются при сохранении настроек."
                           wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
                    <GridPane fx:id="quantifiersGrid" hgap="12" vgap="8" style="-fx-background-color: transparent;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="70" prefWidth="90"/>
                            <ColumnConstraints minWidth="80" prefWidth="90"/>
                            <ColumnConstraints minWidth="50" prefWidth="60"/>
                            <ColumnConstraints minWidth="50" prefWidth="60"/>
                            <ColumnConstraints minWidth="50" prefWidth="60"/>
                            <ColumnConstraints minWidth="50" prefWidth="60"/>
                            <ColumnConstraints minWidth="55" prefWidth="70"/>
                        </columnConstraints>
                        <Label text="Событие" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                        <Label text="Source" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                        <Label text="SV" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                        <Label text="Min" GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                        <Label text="Max" GridPane.columnIndex="4" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                        <Label text="Step" GridPane.columnIndex="5" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                        <Label text="Action" GridPane.columnIndex="6" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                        <Label text="Air" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555;"/>
                        <ComboBox fx:id="cmbQuantAirSource" prefWidth="85" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtQuantAirSv" prefWidth="50" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtQuantAirMin" prefWidth="50" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtQuantAirMax" prefWidth="50" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtQuantAirStep" prefWidth="50" GridPane.columnIndex="5" GridPane.rowIndex="1"/>
                        <CheckBox fx:id="chkQuantAirAction" GridPane.columnIndex="6" GridPane.rowIndex="1"/>
                        <Label text="Drum" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555;"/>
                        <ComboBox fx:id="cmbQuantDrumSource" prefWidth="85" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtQuantDrumSv" prefWidth="50" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtQuantDrumMin" prefWidth="50" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtQuantDrumMax" prefWidth="50" GridPane.columnIndex="4" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtQuantDrumStep" prefWidth="50" GridPane.columnIndex="5" GridPane.rowIndex="2"/>
                        <CheckBox fx:id="chkQuantDrumAction" GridPane.columnIndex="6" GridPane.rowIndex="2"/>
                        <Label text="Damper" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #555555;"/>
                        <ComboBox fx:id="cmbQuantDamperSource" prefWidth="85" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtQuantDamperSv" prefWidth="50" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtQuantDamperMin" prefWidth="50" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtQuantDamperMax" prefWidth="50" GridPane.columnIndex="4" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtQuantDamperStep" prefWidth="50" GridPane.columnIndex="5" GridPane.rowIndex="3"/>
                        <CheckBox fx:id="chkQuantDamperAction" GridPane.columnIndex="6" GridPane.rowIndex="3"/>
                        <Label text="Burner" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #555555;"/>
                        <ComboBox fx:id="cmbQuantBurnerSource" prefWidth="85" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtQuantBurnerSv" prefWidth="50" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtQuantBurnerMin" prefWidth="50" GridPane.columnIndex="3" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtQuantBurnerMax" prefWidth="50" GridPane.columnIndex="4" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtQuantBurnerStep" prefWidth="50" GridPane.columnIndex="5" GridPane.rowIndex="4"/>
                        <CheckBox fx:id="chkQuantBurnerAction" GridPane.columnIndex="6" GridPane.rowIndex="4"/>
                    </GridPane>
                </VBox>
            </ScrollPane>
        </Tab>
    </TabPane>

    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 16 0 0 0;">
        <Button fx:id="btnSave" text="Сохранить"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 24; -fx-background-radius: 4;"/>
        <Button fx:id="btnCancel" text="Отмена"
                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 8 24; -fx-background-radius: 4;"/>
    </HBox>
</VBox>
