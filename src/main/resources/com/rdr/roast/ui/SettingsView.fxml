<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rdr.roast.ui.SettingsController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color: #1a1a2e; -fx-padding: 24;">
    <fx:define>
        <ToggleGroup fx:id="tglUnit"/>
    </fx:define>

    <Label text="Settings"
           style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <GridPane hgap="16" vgap="12" style="-fx-background-color: transparent;">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="120"/>
            <ColumnConstraints minWidth="200" prefWidth="280"/>
        </columnConstraints>

        <!-- Data Source -->
        <Label text="Data Source" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-text-fill: white; -fx-font-size: 14;"/>
        <ComboBox fx:id="cmbSource" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"
                  style="-fx-background-color: #16213e; -fx-text-fill: white;"/>

        <!-- Port fields container (hidden for Simulator) -->
        <VBox fx:id="portFieldsContainer" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1"
              spacing="12" style="-fx-background-color: transparent;">
            <GridPane hgap="16" vgap="8" style="-fx-background-color: transparent;">
                <columnConstraints>
                    <ColumnConstraints minWidth="100" prefWidth="120"/>
                    <ColumnConstraints minWidth="200" prefWidth="280"/>
                </columnConstraints>
                <Label text="COM Port" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-text-fill: white; -fx-font-size: 14;"/>
                <TextField fx:id="txtPort" promptText="COM4" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #888888;"/>

                <Label text="Baud Rate" GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-text-fill: white; -fx-font-size: 14;"/>
                <TextField fx:id="txtBaudRate" promptText="9600" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"
                           style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #888888;"/>

                <Label text="Slave ID" GridPane.columnIndex="0" GridPane.rowIndex="2"
                       style="-fx-text-fill: white; -fx-font-size: 14;"/>
                <TextField fx:id="txtSlaveId" promptText="1" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"
                           style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #888888;"/>
            </GridPane>
        </VBox>

        <!-- Temperature Unit -->
        <Label text="Temperature Unit" GridPane.columnIndex="0" GridPane.rowIndex="2"
               style="-fx-text-fill: white; -fx-font-size: 14;"/>
        <HBox spacing="16" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <RadioButton fx:id="rbCelsius" text="°C" toggleGroup="$tglUnit" selected="true"
                         style="-fx-text-fill: white;"/>
            <RadioButton fx:id="rbFahrenheit" text="°F" toggleGroup="$tglUnit"
                         style="-fx-text-fill: white;"/>
        </HBox>

        <!-- Folder for .alog files -->
        <Label text="Save folder (.alog)" GridPane.columnIndex="0" GridPane.rowIndex="3"
               style="-fx-text-fill: white; -fx-font-size: 14;"/>
        <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <TextField fx:id="txtSavePath" prefWidth="220" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #888888;"/>
            <Button fx:id="btnBrowse" text="Browse"
                    style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-padding: 8 16;"/>
        </HBox>

        <!-- Buttons -->
        <HBox spacing="12" alignment="CENTER_RIGHT" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4">
            <Button fx:id="btnSave" text="Save"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 8 24;"/>
            <Button fx:id="btnCancel" text="Cancel"
                    style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-padding: 8 24;"/>
        </HBox>
    </GridPane>
</VBox>
