<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rdr.roast.ui.SettingsController"
      spacing="0" alignment="TOP_CENTER"
      style="-fx-background-color: #ffffff; -fx-padding: 16; -fx-text-fill: #333333;">
    <fx:define>
        <ToggleGroup fx:id="tglUnit"/>
    </fx:define>

    <TabPane fx:id="settingsTabPane" VBox.vgrow="ALWAYS">
        <Tab text="Устройство">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="Источник данных (Meter)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <ComboBox fx:id="cmbSource" prefWidth="280"
                              style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>

                    <Label text="Кривые" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="16">
                        <CheckBox fx:id="chkCurveET" text="ET" style="-fx-text-fill: #333333;"/>
                        <CheckBox fx:id="chkCurveBT" text="BT" style="-fx-text-fill: #333333;"/>
                    </HBox>

                    <Label text="LCD" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="16">
                        <CheckBox fx:id="chkLcdET" text="ET" style="-fx-text-fill: #333333;"/>
                        <CheckBox fx:id="chkLcdBT" text="BT" style="-fx-text-fill: #333333;"/>
                        <CheckBox fx:id="chkSwapLcds" text="Swap" style="-fx-text-fill: #333333;"/>
                    </HBox>

                    <CheckBox fx:id="chkDeviceLogging" text="Logging" style="-fx-text-fill: #333333;"/>

                    <Label text="Профиль подключения"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cmbPreset" prefWidth="180" promptText="— Текущий —"
                                  style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Button fx:id="btnLoadPreset" text="Загрузить"
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                        <Button fx:id="btnSavePreset" text="Сохранить как..."
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                    </HBox>

                    <VBox fx:id="portFieldsContainer" spacing="12" style="-fx-background-color: transparent;">
                        <GridPane hgap="16" vgap="8" style="-fx-background-color: transparent;">
                            <columnConstraints>
                                <ColumnConstraints minWidth="100" prefWidth="140"/>
                                <ColumnConstraints minWidth="200" prefWidth="280"/>
                            </columnConstraints>
                            <Label text="Connection" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <ComboBox fx:id="cmbTransport" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                      style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>

                            <Label fx:id="lblHost" text="Host (TCP)" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtHost" promptText="10.0.0.9" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblTcpPort" text="Port (TCP)" GridPane.columnIndex="0" GridPane.rowIndex="2"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtTcpPort" promptText="502" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblComPort" text="COM Port" GridPane.columnIndex="0" GridPane.rowIndex="3"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtPort" promptText="COM4" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblBaudRate" text="Baud Rate" GridPane.columnIndex="0" GridPane.rowIndex="4"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtBaudRate" promptText="9600" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblSlaveId" text="Slave ID" GridPane.columnIndex="0" GridPane.rowIndex="5"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtSlaveId" promptText="1" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="5"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblPhidgetEt" text="Phidget ET channel" GridPane.columnIndex="0" GridPane.rowIndex="6"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtPhidgetEtChannel" promptText="1" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="6"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                            <Label fx:id="lblPhidgetBt" text="Phidget BT channel" GridPane.columnIndex="0" GridPane.rowIndex="7"
                                   style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtPhidgetBtChannel" promptText="2" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="7"
                                       style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        </GridPane>
                    </VBox>

                    <Label text="Интервал опроса (сек)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <TextField fx:id="txtSamplingIntervalSec" promptText="1" prefWidth="80"
                               style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                    <Label text="Единицы температуры"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="16">
                        <RadioButton fx:id="rbCelsius" text="°C" toggleGroup="$tglUnit" selected="true"
                                     style="-fx-text-fill: #333333;"/>
                        <RadioButton fx:id="rbFahrenheit" text="°F" toggleGroup="$tglUnit"
                                     style="-fx-text-fill: #333333;"/>
                    </HBox>

                    <Label text="Папка сохранения (.alog)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8">
                        <TextField fx:id="txtSavePath" prefWidth="220" HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Button fx:id="btnBrowse" text="Обзор..."
                                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 8 16; -fx-background-radius: 4;"/>
                    </HBox>

                    <Label text="Сервер (reference)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <TextField fx:id="txtServerBaseUrl" promptText="https://example.com/api/v1" prefWidth="280"
                               style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                    <Label text="API токен (опционально)"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <TextField fx:id="txtServerToken" promptText="Bearer token" prefWidth="280"
                               style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                </VBox>
            </ScrollPane>
        </Tab>

        <Tab text="Порты">
            <TabPane fx:id="portsTabPane">
                <Tab text="ET/BT">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                        <VBox spacing="10" style="-fx-padding: 8; -fx-background-color: transparent;">
                            <Label text="Параметры для устройств не-Modbus (COM)" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                            <GridPane hgap="12" vgap="6">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="90" prefWidth="100"/>
                                    <ColumnConstraints minWidth="120" prefWidth="200"/>
                                </columnConstraints>
                                <Label text="Comm Port" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtEtBtPort" promptText="COM4" prefWidth="180" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Baud Rate" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtEtBtBaudRate" promptText="115200" prefWidth="180" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Byte Size" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtEtBtByteSize" promptText="8" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Parity" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtEtBtParity" promptText="N" prefWidth="60" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Stopbits" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtEtBtStopbits" promptText="1" prefWidth="60" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Timeout" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtEtBtTimeout" promptText="1.0" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="5"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </GridPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
                <Tab text="Modbus">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                        <VBox spacing="10" style="-fx-padding: 8; -fx-background-color: transparent;">
                            <Label text="Serial" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                            <GridPane hgap="8" vgap="4">
                                <columnConstraints><ColumnConstraints minWidth="70"/><ColumnConstraints minWidth="100"/></columnConstraints>
                                <Label text="Comm Port" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtModbusPort" promptText="COM5" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Baud Rate" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtModbusBaud" promptText="9600" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </GridPane>
                            <Label text="TCP/UDP" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                            <GridPane hgap="8" vgap="4">
                                <columnConstraints><ColumnConstraints minWidth="70"/><ColumnConstraints minWidth="120"/></columnConstraints>
                                <Label text="Type" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555;"/>
                                <ComboBox fx:id="cmbModbusType" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                          style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Host" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtModbusHost" promptText="10.0.0.9" prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Port" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtModbusTcpPort" promptText="502" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </GridPane>
                            <HBox spacing="8">
                                <CheckBox fx:id="chkModbusLittleEndian" text="little-endian" style="-fx-text-fill: #333333;"/>
                                <CheckBox fx:id="chkModbusOptimize" text="optimize" style="-fx-text-fill: #333333;"/>
                                <CheckBox fx:id="chkModbusFetchFullBlocks" text="fetch full blocks" style="-fx-text-fill: #333333;"/>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </Tab>
                <Tab text="S7">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                        <VBox spacing="10" style="-fx-padding: 8; -fx-background-color: transparent;">
                            <GridPane hgap="8" vgap="4">
                                <columnConstraints><ColumnConstraints minWidth="60"/><ColumnConstraints minWidth="120"/></columnConstraints>
                                <Label text="Host" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtS7Host" promptText="127.0.0.1" prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Port" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtS7Port" promptText="102" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Rack" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtS7Rack" promptText="0" prefWidth="60" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Slot" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtS7Slot" promptText="0" prefWidth="60" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </GridPane>
                            <HBox spacing="8">
                                <CheckBox fx:id="chkS7Optimize" text="optimize" style="-fx-text-fill: #333333;"/>
                                <CheckBox fx:id="chkS7FetchFullBlocks" text="fetch full blocks" style="-fx-text-fill: #333333;"/>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </Tab>
                <Tab text="WebSocket">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                        <VBox spacing="10" style="-fx-padding: 8; -fx-background-color: transparent;">
                            <Label text="Machine" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                            <GridPane hgap="8" vgap="4">
                                <columnConstraints><ColumnConstraints minWidth="50"/><ColumnConstraints minWidth="160"/></columnConstraints>
                                <Label text="Host" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtWsHost" promptText="127.0.0.1" prefWidth="160" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Port" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtWsPort" promptText="80" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Path" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555;"/>
                                <TextField fx:id="txtWsPath" promptText="WebSocket" prefWidth="160" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </GridPane>
                            <Label text="Timeout (sec)" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                            <HBox spacing="12">
                                <Label text="Connect" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                                <TextField fx:id="txtWsConnectTimeout" promptText="4.0" prefWidth="50"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Reconnect" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                                <TextField fx:id="txtWsReconnectTimeout" promptText="2.0" prefWidth="50"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="Request" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                                <TextField fx:id="txtWsRequestTimeout" promptText="0.5" prefWidth="50"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </HBox>
                            <Label text="Commands" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                            <HBox spacing="8">
                                <Label text="Data request" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                                <TextField fx:id="txtWsDataRequest" promptText="getData" prefWidth="120"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </HBox>
                            <Label text="Messages" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                            <HBox spacing="8">
                                <Label text="CHARGE" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                                <TextField fx:id="txtWsChargeMessage" promptText="startRoasting" prefWidth="140"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                                <Label text="DROP" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                                <TextField fx:id="txtWsDropMessage" promptText="endRoasting" prefWidth="120"
                                           style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4;"/>
                            </HBox>
                            <HBox spacing="8">
                                <CheckBox fx:id="chkWsStartOnCharge" text="START on CHARGE" style="-fx-text-fill: #333333;"/>
                                <CheckBox fx:id="chkWsOffOnDrop" text="OFF on DROP" style="-fx-text-fill: #333333;"/>
                            </HBox>
                            <CheckBox fx:id="chkWsCompression" text="compression" style="-fx-text-fill: #333333;"/>
                        </VBox>
                    </ScrollPane>
                </Tab>
            </TabPane>
        </Tab>

        <Tab text="График">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="График"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Темп. мин" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtChartTempMin" prefWidth="60"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>
                        <Label text="Темп. макс" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtChartTempMax" prefWidth="60"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>
                    </HBox>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="RoR мин" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtChartRorMin" prefWidth="60"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>
                        <Label text="RoR макс" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtChartRorMax" prefWidth="60"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>
                        <Label text="Длительность (мин)" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtChartTimeRange" prefWidth="50"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333;"/>
                    </HBox>

                    <CheckBox fx:id="chkChartShowGrid" text="Показать сетку"
                              style="-fx-text-fill: #333333;"/>

                    <Label text="Толщина линий"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="BT" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartBtLineWidth" prefWidth="40" promptText="2"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="ET" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartEtLineWidth" prefWidth="40" promptText="2"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="RoR BT" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartRorLineWidth" prefWidth="40" promptText="1.5"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <Label text="RoR ET" style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
                        <TextField fx:id="txtChartRefLineWidth" prefWidth="40" promptText="1.5"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </HBox>

                    <Label text="Фон / Сетка"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="txtChartBackground" promptText="#ffffff" prefWidth="80"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                        <TextField fx:id="txtChartGridColor" promptText="#d3d3d3" prefWidth="80"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </Tab>

        <Tab text="Цвета">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="12" style="-fx-background-color: transparent;">
                    <Label text="Живой BT / Живой ET"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>

                    <GridPane hgap="12" vgap="8" style="-fx-background-color: transparent;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="60" prefWidth="70"/>
                            <ColumnConstraints minWidth="120" prefWidth="140"/>
                            <ColumnConstraints minWidth="70" prefWidth="90"/>
                        </columnConstraints>
                        <Label text="BT" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveBt" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtColorLiveBt" promptText="#d4483b" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="0"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="ET" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveEt" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtColorLiveEt" promptText="#3498db" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="1"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="RoR BT" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveRorBt" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtColorLiveRorBt" promptText="#2c3e50" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="2"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="RoR ET" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorLiveRorEt" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtColorLiveRorEt" promptText="#95a5a6" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="3"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </GridPane>

                    <Label text="Цвета reference"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>

                    <GridPane hgap="12" vgap="8" style="-fx-background-color: transparent;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="60" prefWidth="70"/>
                            <ColumnConstraints minWidth="120" prefWidth="140"/>
                            <ColumnConstraints minWidth="70" prefWidth="90"/>
                        </columnConstraints>
                        <Label text="BT" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorRefBt" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtColorRefBt" promptText="#d4483b" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="0"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>

                        <Label text="ET" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="colorRefEt" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtColorRefEt" promptText="#3498db" prefWidth="80" GridPane.columnIndex="2" GridPane.rowIndex="1"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </GridPane>

                    <Label text="Прозрачность ref"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Slider fx:id="sldRefAlpha" min="0" max="255" value="80" prefWidth="180" showTickLabels="false" showTickMarks="false"/>
                        <TextField fx:id="txtColorRefAlpha" promptText="80" prefWidth="50"
                                   style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-prompt-text-fill: #888888;"/>
                    </HBox>

                    <Button fx:id="btnResetColors" text="Сбросить..."
                            style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
                </VBox>
            </ScrollPane>
        </Tab>
    </TabPane>

    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 16 0 0 0;">
        <Button fx:id="btnSave" text="Сохранить"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 24; -fx-background-radius: 4;"/>
        <Button fx:id="btnCancel" text="Отмена"
                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 8 24; -fx-background-radius: 4;"/>
    </HBox>
</VBox>
