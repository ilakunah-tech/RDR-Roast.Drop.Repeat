<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rdr.roast.ui.EventButtonsController"
      spacing="12" style="-fx-background-color: #ffffff; -fx-padding: 16; -fx-text-fill: #333333;">

    <Label text="Events → Buttons (custom Modbus buttons)"
           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #555555;"/>
    <Label text="Add buttons with label, command string (write/wcoil/sleep), visibility and color. They appear in the main window and run the command when clicked."
           style="-fx-text-fill: #888888; -fx-font-size: 11px; -fx-wrap-text: true;"/>

    <TableView fx:id="table" prefHeight="220" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colLabel" text="Label" prefWidth="90"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="100"/>
            <TableColumn fx:id="colAction" text="Action" prefWidth="100"/>
            <TableColumn fx:id="colCommand" text="Command" prefWidth="200"/>
            <TableColumn fx:id="colVisibility" text="Visible" prefWidth="55"/>
            <TableColumn fx:id="colBgColor" text="Color" prefWidth="70"/>
        </columns>
    </TableView>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button fx:id="btnAdd" text="Add"
                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
        <Button fx:id="btnEdit" text="Edit"
                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
        <Button fx:id="btnDelete" text="Delete"
                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 4;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
        <Button fx:id="btnOk" text="OK" defaultButton="true"
                style="-fx-background-color: #4A90D9; -fx-text-fill: white; -fx-padding: 6 16; -fx-background-radius: 4;"/>
        <Button fx:id="btnCancel" text="Cancel" cancelButton="true"
                style="-fx-background-color: #e8e8e8; -fx-text-fill: #333333; -fx-padding: 6 16; -fx-background-radius: 4;"/>
    </HBox>
</VBox>
