<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rdr.roast.ui.LoginController"
      styleClass="drawer-form"
      spacing="14" alignment="TOP_LEFT" minWidth="340" prefWidth="340" fillWidth="true">
    <Label text="Вход на сервер" styleClass="drawer-sheet-title"/>
    <Label text="Авторизуйтесь, чтобы подгружать расписание, эталоны и отправлять профили на сервер." styleClass="drawer-sheet-subtitle"/>
    <VBox spacing="10" styleClass="drawer-section-card, drawer-hero-card">
        <Label fx:id="lblEmail" text="Email" styleClass="secondary-field-label"/>
        <TextField fx:id="txtEmail" promptText="email@example.com" styleClass="secondary-input"/>
        <Label fx:id="lblPassword" text="Пароль" styleClass="secondary-field-label"/>
        <PasswordField fx:id="txtPassword" promptText="Пароль" styleClass="secondary-input"/>
        <CheckBox fx:id="chkRemember" text="Запомнить email" styleClass="secondary-hint-label"/>
    </VBox>
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="drawer-toolbar">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnCancel" text="Отмена" cancelButton="true" styleClass="btn-secondary"/>
        <Button fx:id="btnOk" text="Войти" defaultButton="true" styleClass="btn-primary"/>
    </HBox>
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="secondary-link-row">
        <Hyperlink fx:id="linkRegister" text="Регистрация" styleClass="secondary-hint-label"/>
        <Hyperlink fx:id="linkResetPassword" text="Восстановление пароля" styleClass="secondary-hint-label"/>
    </HBox>
    <Label fx:id="lblError" text="" wrapText="true" maxWidth="320" visible="false" managed="false" styleClass="secondary-error-label"/>
</VBox>
