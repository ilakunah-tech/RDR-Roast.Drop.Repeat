<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rdr.roast.ui.FinishRoastController"
      prefWidth="260" minWidth="260" maxWidth="260"
      spacing="14" style="-fx-background-color: #fafafa; -fx-padding: 14; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">
    <Label text="Finish roast"
           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="80" prefWidth="90"/>
            <ColumnConstraints minWidth="120" prefWidth="140"/>
        </columnConstraints>
        <Label text="Start time" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-text-fill: #666; -fx-font-size: 11;"/>
        <TextField fx:id="txtStartTime" promptText="00:00" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="End time" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-text-fill: #666; -fx-font-size: 11;"/>
        <TextField fx:id="txtEndTime" promptText="00:00" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Start weight (kg)" GridPane.columnIndex="0" GridPane.rowIndex="2"
               style="-fx-text-fill: #666; -fx-font-size: 11;"/>
        <TextField fx:id="txtStartWeight" promptText="—" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="End weight (kg)" GridPane.columnIndex="0" GridPane.rowIndex="3"
               style="-fx-text-fill: #666; -fx-font-size: 11;"/>
        <TextField fx:id="txtEndWeight" promptText="—" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Weight loss" GridPane.columnIndex="0" GridPane.rowIndex="4"
               style="-fx-text-fill: #666; -fx-font-size: 11;"/>
        <Label fx:id="lblWeightLoss" text="—" GridPane.columnIndex="1" GridPane.rowIndex="4"
               style="-fx-text-fill: #333; -fx-font-size: 12;"/>

        <Label text="Notes" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.valignment="TOP"
               style="-fx-text-fill: #666; -fx-font-size: 11;"/>
        <TextArea fx:id="txtNotes" prefRowCount="2" prefWidth="140" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 4 0 0 0;">
        <Button fx:id="btnDontSave" text="Don't save"
                style="-fx-background-color: #bdc3c7; -fx-text-fill: #333; -fx-font-size: 12; -fx-padding: 6 14; -fx-background-radius: 4;"/>
        <Button fx:id="btnSave" text="Save .alog"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 6 16; -fx-background-radius: 4;"/>
    </HBox>
</VBox>
